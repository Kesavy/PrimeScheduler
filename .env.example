# Trello Power-Up credentials (trello.com/power-ups/admin)
TRELLO_API_KEY=
TRELLO_OAUTH_SECRET=

# Upstash Redis (console.upstash.com → Redis → tvůj store → REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (console.upstash.com → QStash → Keys)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Vygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# URL tvého Vercel deploye (nastav po prvním deployi)
BACKEND_URL=https://primetime-backend.vercel.app

# Origin Power-Up frontendu (GitHub Pages nebo vlastní doména)
ALLOWED_ORIGIN=https://praceburian-debug.github.io
